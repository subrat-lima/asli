{
  "manifest_version": 3,
  "name": "Asli",
  "version": "0.0.5",
  "description": "A browser extension to help people stay protected by identifying and categorizing official, unofficial and scam websites.",
  "permissions": [
    "tabs",
    "alarms",
    "storage"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "background.js"
    ],
    "type": "module"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "asli@subrat.lima",
      "strict_min_version": "109.0"
    }
  },
  "action": {
    "default_title": "Asli"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "data.min.json",
        "metadata.json",
        "blocked.html",
        "blocked.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}

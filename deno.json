{
  "imports": {
    "@std/path": "jsr:@std/path@1"
  },
  "tasks": {
    "fmt": "deno fmt .",
    "lint": "deno lint --fix",
    "format": "deno fmt . && deno lint --fix",
    "app": "./scripts/app.sh",
    "data": "./scripts/data.sh",
    "setup": "./scripts/setup.sh",
    "release": "./scripts/release.sh"
  },
  "fmt": {
    "indentWidth": 2,
    "lineWidth": 80,
    "semiColons": true,
    "singleQuote": false,
    "useTabs": false
  }
}
